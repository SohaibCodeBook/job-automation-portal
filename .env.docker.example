# Optional root env for docker compose variable substitution (build args).
# Copy if you need to override defaults: cp .env.docker.example .env
#
# Services load secrets from:
#   backend  → backend/.env
#   frontend → frontend/.env.local
#
# The backend entrypoint rewrites DATABASE_URL localhost → host.docker.internal
# so your existing backend/.env works inside Docker.

# Build-time only (browser API URL baked into frontend image)
NEXT_PUBLIC_API_URL=http://localhost:8000

NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Example if you prefer a root .env instead of editing backend/.env:
# DATABASE_URL=postgresql+asyncpg://user:password@host.docker.internal:5433/jobsdb
# JWT_SECRET=change-me-min-16-chars
# INTERNAL_API_KEY=change-me-min-16-chars
# AUTH_SECRET=change-me-min-32-chars
# FRONTEND_BASE_URL=http://localhost:3000
# CORS_ORIGINS=http://localhost:3000
