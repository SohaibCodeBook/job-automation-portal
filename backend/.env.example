# Application
ENVIRONMENT=development
PROJECT_NAME=Job Application Workflow API

# API
API_V1_PREFIX=/api/v1

# Database (async SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/jobsdb

# Auth (JWT for API access; must match frontend AUTH_SECRET for email token links)
JWT_SECRET=

# Frontend origin for verification / password-reset links
FRONTEND_BASE_URL=http://localhost:3000

# Server-to-server calls (e.g. NextAuth Google sync)
INTERNAL_API_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# CORS (comma-separated origins; must include the Next.js app origin)
CORS_ORIGINS=http://localhost:3000
